{
  "$id": "urn:idp:MfaRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "POST /mfa の form リクエスト。factor_type に応じて credential の形式が決まる (factor 固有の検証ロジックは Authentication component が担う)。CSRF は double-submit cookie と hidden form value の一致で検証する。",
  "properties": {
    "request_id": {
      "type": "string",
      "format": "uuid"
    },
    "factor_type": {
      "type": "string",
      "enum": [
        "totp",
        "webauthn",
        "hwk",
        "swk"
      ]
    },
    "credential": {
      "type": "string"
    },
    "csrf": {
      "type": "string"
    }
  },
  "required": [
    "request_id",
    "factor_type",
    "credential",
    "csrf"
  ]
}
