{
  "$id": "urn:idp:AdminConsentResponse",
  "type": "object",
  "additionalProperties": false,
  "description": "管理 API が返す所属テナント内の Consent 表現。",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "sub": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "state": {
      "type": "string",
      "enum": [
        "granted",
        "revoked",
        "expired"
      ]
    },
    "granted_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "tenant_id",
    "sub",
    "client_id",
    "scopes",
    "state",
    "granted_at",
    "expires_at"
  ]
}
