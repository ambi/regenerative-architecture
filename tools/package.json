{
  "name": "tools",
  "private": true,
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "scl-to-html": "bun run scl-to-html/src/main.ts",
    "yaml-check": "bun run yaml-check/src/main.ts",
    "yaml-check:work-items": "bun run yaml-check/src/main.ts --schema=work-item '../changes/*/work-item.yaml'",
    "yaml-check:completion-reports": "bun run yaml-check/src/main.ts --schema=completion-report '../changes/*/completion-report.yaml'",
    "yaml-check:scl": "bun run yaml-check/src/main.ts --schema=scl ../ra-idp-go/spec/scl.yaml ../tools/scl-to-html/spec/scl.yaml",
    "yaml-check:all": "bun run yaml-check:work-items && bun run yaml-check:completion-reports && bun run yaml-check:scl"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
