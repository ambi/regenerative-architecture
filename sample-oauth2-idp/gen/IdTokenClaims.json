{
  "$id": "urn:idp:IdTokenClaims",
  "type": "object",
  "additionalProperties": false,
  "description": "OIDC ID Token クレーム。TTL 3600 秒。",
  "properties": {
    "iss": {
      "type": "string",
      "format": "uri"
    },
    "sub": {
      "type": "string"
    },
    "aud": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "exp": {
      "type": "integer"
    },
    "iat": {
      "type": "integer"
    },
    "auth_time": {
      "type": "integer"
    },
    "nonce": {
      "type": "string"
    },
    "acr": {
      "type": "string"
    },
    "amr": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "azp": {
      "type": "string"
    },
    "at_hash": {
      "type": "string"
    },
    "c_hash": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "preferred_username": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "email_verified": {
      "type": "boolean"
    }
  },
  "required": [
    "iss",
    "sub",
    "aud",
    "exp",
    "iat",
    "auth_time"
  ]
}
