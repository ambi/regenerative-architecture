{
  "$id": "urn:idp:PasswordResetTokenRecord",
  "type": "object",
  "additionalProperties": false,
  "description": "パスワードリセット用の単発消費トークン (ADR-030)。\ntoken は base64url の 32 バイト乱数で、保存時は SHA-256 hash のみ。\n期限切れ / consume 済みの行は GC するが、INSERT 時に同 sub の未消費を\n失効させる軽い掃除も行う。\n",
  "properties": {
    "sub": {
      "type": "string"
    },
    "token_hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "consumed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "sub",
    "token_hash",
    "created_at",
    "expires_at"
  ]
}
