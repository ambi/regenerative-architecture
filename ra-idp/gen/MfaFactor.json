{
  "$id": "urn:idp:MfaFactor",
  "type": "object",
  "additionalProperties": false,
  "description": "ユーザーが登録した第二要素 (MFA) 1 件。Totp の場合 secret は base32 で保存し、認証時に RFC 6238 (T0=0, STEP=30s, 6-digit) で評価する。User.mfa_enrolled の真値はこの集合の非空性と同義。",
  "properties": {
    "sub": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "totp",
        "webauthn",
        "hwk",
        "swk"
      ]
    },
    "secret": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_used_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "sub",
    "type",
    "created_at"
  ]
}
