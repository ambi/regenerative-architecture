{
  "$id": "urn:idp:AuthorizeParameters",
  "type": "object",
  "additionalProperties": false,
  "description": "GET /authorize クエリパラメータ。",
  "properties": {
    "response_type": {
      "type": "string",
      "enum": [
        "code"
      ]
    },
    "client_id": {
      "type": "string"
    },
    "redirect_uri": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "nonce": {
      "type": "string"
    },
    "code_challenge": {
      "type": "string"
    },
    "code_challenge_method": {
      "type": "string",
      "enum": [
        "S256"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "max_age": {
      "type": "integer"
    },
    "id_token_hint": {
      "type": "string"
    },
    "request_uri": {
      "type": "string"
    }
  },
  "required": [
    "response_type",
    "client_id",
    "redirect_uri",
    "code_challenge",
    "code_challenge_method"
  ]
