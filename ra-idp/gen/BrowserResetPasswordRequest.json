{
  "$id": "urn:idp:BrowserResetPasswordRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "SPA が POST /api/auth/reset_password に送る JSON。email リンクに含まれた単発消費 token と新パスワードを受ける (ADR-030)。",
  "properties": {
    "token": {
      "type": "string"
    },
    "new_password": {
      "type": "string"
    }
  },
  "required": [
    "token",
    "new_password"
  ]
}
