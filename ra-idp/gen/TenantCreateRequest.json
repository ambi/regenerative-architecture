{
  "$id": "urn:idp:TenantCreateRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "管理者が新規テナントを登録する JSON リクエスト (ADR-032)。`id` は URL-safe slug。",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    }
  },
  "required": [
    "id",
    "display_name"
  ]
}
