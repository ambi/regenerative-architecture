{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!bun.lock",
      "!gen",
      "!ui/dist",
      "!ui/src/routeTree.gen.ts",
      "!ui/**/*.css",
      "!ui/**/*.html",
      "!ui/**/*.json",
      "!infra/observability/grafana/dashboards/*.json",
      "!infra/load-tests/k6/*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off",
        "useTemplate": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "off" } }
  },
  "overrides": [
    {
      "includes": ["adapters/**", "infra/**"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    },
    {
      "includes": ["ui/**/*.ts", "ui/**/*.tsx"],
      "linter": {
        "rules": {
          "style": {
            "useImportType": "warn"
          },
          "correctness": {
            "noUnusedImports": "error"
          }
        }
      }
    }
  ]
}
