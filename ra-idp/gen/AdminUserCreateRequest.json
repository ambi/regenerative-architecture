{
  "$id": "urn:idp:AdminUserCreateRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "管理者がユーザーを作成する JSON リクエスト。初期パスワードには password_policy を適用する。",
  "properties": {
    "preferred_username": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "password": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "email_verified": {
      "type": "boolean"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "preferred_username",
    "password",
    "email_verified",
    "roles"
  ]
}
