{
  "$id": "urn:idp:RefreshTokenRecord",
  "type": "object",
  "additionalProperties": false,
  "description": "リフレッシュトークンのストアレコード。プレーン値は保存しない。状態は RefreshTokenLifecycle 状態機械に従う。",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string"
    },
    "hash": {
      "type": "string"
    },
    "family_id": {
      "type": "string",
      "format": "uuid"
    },
    "parent_id": {
      "type": "string",
      "format": "uuid"
    },
    "client_id": {
      "type": "string"
    },
    "sub": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "state": {
      "type": "string",
      "enum": [
        "active",
        "rotated",
        "revoked",
        "expired"
      ]
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "absolute_expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "sender_constraint": {
      "$ref": "#/components/schemas/RefreshTokenSenderConstraint"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "hash",
    "family_id",
    "client_id",
    "sub",
    "scopes",
    "state",
    "issued_at",
    "expires_at",
    "absolute_expires_at"
  ]
}
