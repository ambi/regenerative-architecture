{
  "name": "tools",
  "private": true,
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "scl-to-html": "bun run scl-to-html/src/main.ts",
    "scl-to-html:ra-idp-go": "bun run scl-to-html/src/main.ts --scl ../ra-idp-go/spec/scl.yaml --title ra-idp-go --out ../ra-idp-go/spec/ra-idp-go.html",
    "scl-to-html:ra-idp-go:full": "bun run scl-to-html/src/main.ts --scl ../ra-idp-go/spec/scl.yaml --decisions ../ra-idp-go/decisions --work-items ../ra-idp-go/work-items --title ra-idp-go --out ../ra-idp-go/spec/ra-idp-go.full.html",
    "scl-to-html:self": "bun run scl-to-html/src/main.ts --scl scl-to-html/spec/scl.yaml --title scl-to-html --out scl-to-html/spec/scl-to-html.html",
    "scl-to-jsonschema": "bun run scl-to-jsonschema/src/main.ts",
    "scl-to-jsonschema:ra-idp-go": "bun run scl-to-jsonschema/src/main.ts --scl ../ra-idp-go/spec/scl.yaml --out ../ra-idp-go/spec/ra-idp-go.models.schema.json",
    "scl-to-openapi": "bun run scl-to-openapi/src/main.ts",
    "scl-to-openapi:ra-idp-go": "bun run scl-to-openapi/src/main.ts --scl ../ra-idp-go/spec/scl.yaml --out ../ra-idp-go/spec/ra-idp-go.openapi.json",
    "yaml-check": "bun run yaml-check/src/main.ts",
    "yaml-check:work-items": "bun run yaml-check/src/main.ts --schema=work-item '../ra-idp-go/work-items/*.yaml' '../ra-idp-go/work-items/done/*.yaml' '../work-items/*.yaml' '../work-items/done/*.yaml'",
    "yaml-check:scl": "bun run yaml-check/src/main.ts --schema=scl ../ra-idp-go/spec/scl.yaml '../ra-idp-go/spec/contexts/*.yaml' ../tools/scl-to-html/spec/scl.yaml ../tools/yaml-check/spec/scl.yaml ../tools/scl-to-jsonschema/spec/scl.yaml ../tools/scl-to-openapi/spec/scl.yaml",
    "yaml-check:all": "bun run yaml-check:work-items && bun run yaml-check:scl"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "markdown-it": "^14.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
