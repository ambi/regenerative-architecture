{
  "$id": "urn:idp:AdminClientCreateRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "管理者が所属テナントに OAuth client を作成する。生成された client_secret は作成応答で一度だけ返す。",
  "properties": {
    "redirect_uris": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "minItems": 1
    },
    "client_name": {
      "type": "string",
      "maxLength": 200
    },
    "client_type": {
      "type": "string",
      "enum": [
        "public",
        "confidential"
      ]
    },
    "grant_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "authorization_code",
          "refresh_token",
          "client_credentials",
          "urn:ietf:params:oauth:grant-type:device_code"
        ]
      },
      "minItems": 1
    },
    "response_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "code"
        ]
      }
    },
    "token_endpoint_auth_method": {
      "type": "string",
      "enum": [
        "client_secret_basic",
        "client_secret_post",
        "private_key_jwt",
        "tls_client_auth",
        "none"
      ]
    },
    "scope": {
      "type": "string"
    },
    "jwks_uri": {
      "type": "string",
      "format": "uri"
    },
    "jwks": {},
    "tls_client_auth_subject_dn": {
      "type": "string"
    },
    "fapi_profile": {
      "type": "string",
      "enum": [
        "none",
        "fapi_2_security_profile"
      ]
    },
    "require_pushed_authorization_requests": {
      "type": "boolean"
    },
    "dpop_bound_access_tokens": {
      "type": "boolean"
    }
  },
  "required": [
    "redirect_uris",
    "grant_types"
  ]
}
