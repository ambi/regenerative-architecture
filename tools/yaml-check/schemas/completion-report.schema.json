{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regenerative-architecture/schemas/completion-report.json",
  "title": "Completion Report",
  "description": "ra.md §4.2.1 で規定される完了レポート。changes/<id>/completion-report.yaml に置く。",
  "type": "object",
  "required": ["id", "title", "completed_at", "work_item", "status", "summary", "verification"],
  "anyOf": [
    { "required": ["affected_guarantees_state"] },
    { "required": ["remaining_guarantees_state"] }
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "対応する work-item.yaml の id と一致。",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "completed_at": {
      "oneOf": [{ "type": "string", "format": "date" }, { "type": "string", "format": "date-time" }]
    },
    "work_item": {
      "type": "string",
      "description": "同ディレクトリ内 work-item.yaml への相対パス。"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "cancelled"]
    },
    "summary": {
      "description": "意味上の差分の要約。",
      "type": "string",
      "minLength": 1
    },
    "verification": {
      "description": "検証結果。",
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["cmd"],
            "properties": {
              "cmd": { "type": "string", "minLength": 1 },
              "in": { "type": "string" },
              "result": {}
            }
          }
        ]
      }
    },
    "affected_guarantees_state": {
      "description": "保証義務の状態。",
      "type": "array"
    },
    "remaining_guarantees_state": {
      "description": "保証義務の状態 (旧表記)。`affected_guarantees_state` を推奨。",
      "type": "array"
    },
    "residual_risk": {
      "description": "残リスク。",
      "type": "array"
    },
    "semantic_diff": {
      "description": "意味上の差分の詳細。"
    },
    "traceability": {
      "description": "仕様 ⇄ 実装 / テストへの対応関係。"
    },
    "human_decisions": {
      "description": "人間の判断。"
    },
    "approver_note": {
      "type": "string"
    }
  }
}
