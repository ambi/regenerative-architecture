{
  "$id": "urn:idp:BrowserChangePasswordRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "SPA が POST /api/auth/change_password に送る JSON。認証済みセッション cookie が sub を解決し、CSRF は X-CSRF-Token header で検証する。",
  "properties": {
    "current_password": {
      "type": "string"
    },
    "new_password": {
      "type": "string"
    }
  },
  "required": [
    "current_password",
    "new_password"
  ]
}
