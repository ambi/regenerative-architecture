{
  "$id": "urn:idp:TokenResponse",
  "type": "object",
  "additionalProperties": false,
  "description": "/token 成功時のレスポンスボディ (RFC 6749 §5.1)。発行されたトークン一式と種別を返す。",
  "properties": {
    "access_token": {
      "type": "string"
    },
    "token_type": {
      "type": "string"
    },
    "expires_in": {
      "type": "integer"
    },
    "refresh_token": {
      "type": "string"
    },
    "id_token": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    }
  },
  "required": [
    "access_token",
    "token_type"
  ]
}
