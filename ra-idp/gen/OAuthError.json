{
  "$id": "urn:idp:OAuthError",
  "type": "object",
  "properties": {
    "type": {
      "const": "OAuthError",
      "type": "string"
    },
    "error": {
      "type": "string",
      "enum": [
        "invalid_request",
        "invalid_client",
        "invalid_grant",
        "unauthorized_client",
        "unsupported_grant_type",
        "invalid_scope",
        "invalid_token",
        "server_error",
        "invalid_dpop_proof",
        "access_denied",
        "expired_token",
        "slow_down",
        "insufficient_scope",
        "authorization_pending"
      ]
    },
    "error_description": {
      "type": "string"
    },
    "error_uri": {
      "type": "string"
    }
  },
  "required": [
    "type",
    "error"
  ]
}
