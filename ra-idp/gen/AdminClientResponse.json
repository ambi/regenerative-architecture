{
  "$id": "urn:idp:AdminClientResponse",
  "type": "object",
  "additionalProperties": false,
  "description": "管理 API の client 表現。client_secret と client_secret_hash は契約上含めない。",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "client_type": {
      "type": "string",
      "enum": [
        "public",
        "confidential"
      ]
    },
    "redirect_uris": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "grant_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "authorization_code",
          "refresh_token",
          "client_credentials",
          "urn:ietf:params:oauth:grant-type:device_code"
        ]
      }
    },
    "response_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "code"
        ]
      }
    },
    "token_endpoint_auth_method": {
      "type": "string",
      "enum": [
        "client_secret_basic",
        "client_secret_post",
        "private_key_jwt",
        "tls_client_auth",
        "none"
      ]
    },
    "scope": {
      "type": "string"
    },
    "jwks_uri": {
      "type": "string",
      "format": "uri"
    },
    "jwks": {},
    "tls_client_auth_subject_dn": {
      "type": "string"
    },
    "id_token_signed_response_alg": {
      "type": "string",
      "enum": [
        "PS256",
        "ES256"
      ]
    },
    "require_pushed_authorization_requests": {
      "type": "boolean"
    },
    "dpop_bound_access_tokens": {
      "type": "boolean"
    },
    "fapi_profile": {
      "type": "string",
      "enum": [
        "none",
        "fapi_2_security_profile"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "tenant_id",
    "client_id",
    "client_type",
    "redirect_uris",
    "grant_types",
    "response_types",
    "token_endpoint_auth_method",
    "scope",
    "id_token_signed_response_alg",
    "require_pushed_authorization_requests",
    "dpop_bound_access_tokens",
    "fapi_profile",
    "created_at"
  ]
}
