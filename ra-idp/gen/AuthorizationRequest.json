{
  "$id": "urn:idp:AuthorizationRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "フロー追跡用のサーバー内部中間ステート。",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "tenant_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "received",
        "authentication_pending",
        "authenticated",
        "consent_pending",
        "consented",
        "code_issued",
        "exchanged",
        "rejected",
        "expired"
      ]
    },
    "client_id": {
      "type": "string"
    },
    "redirect_uri": {
      "type": "string",
      "format": "uri"
    },
    "response_type": {
      "type": "string",
      "enum": [
        "code"
      ]
    },
    "scope": {
      "type": "string"
    },
    "state_param": {
      "type": "string"
    },
    "nonce": {
      "type": "string"
    },
    "code_challenge": {
      "type": "string"
    },
    "code_challenge_method": {
      "type": "string",
      "enum": [
        "S256"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "max_age": {
      "type": "integer",
      "minimum": 0
    },
    "par_request_uri": {
      "type": "string"
    },
    "sub": {
      "type": "string"
    },
    "auth_time": {
      "type": "integer"
    },
    "amr": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acr": {
      "type": "string"
    },
    "acr_values": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "state",
    "client_id",
    "redirect_uri",
    "response_type",
    "scope",
    "code_challenge",
    "code_challenge_method",
    "created_at",
    "expires_at"
  ]
}
