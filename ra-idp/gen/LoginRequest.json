{
  "$id": "urn:idp:LoginRequest",
  "type": "object",
  "additionalProperties": false,
  "description": "POST /login の form リクエスト。CSRF は double-submit cookie と hidden form value の一致で検証する。",
  "properties": {
    "request_id": {
      "type": "string",
      "format": "uuid"
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "csrf": {
      "type": "string"
    }
  },
  "required": [
    "request_id",
    "username",
    "password",
    "csrf"
  ]
}
