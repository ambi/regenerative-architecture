{
  "$id": "urn:idp:AdminUserResponse",
  "type": "object",
  "additionalProperties": false,
  "description": "管理 API が返すユーザー表現。password_hash は契約上含めない。",
  "properties": {
    "sub": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "preferred_username": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "email_verified": {
      "type": "boolean"
    },
    "mfa_enrolled": {
      "type": "boolean"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disabled_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "sub",
    "tenant_id",
    "preferred_username",
    "email_verified",
    "mfa_enrolled",
    "roles",
    "created_at"
  ]
}
