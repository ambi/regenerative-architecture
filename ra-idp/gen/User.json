{
  "$id": "urn:idp:User",
  "type": "object",
  "additionalProperties": false,
  "description": "OIDC Core §5.1 標準クレーム + PII 注釈付きユーザー。",
  "properties": {
    "sub": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string"
    },
    "preferred_username": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "password_hash": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "given_name": {
      "type": "string"
    },
    "family_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "email_verified": {
      "type": "boolean"
    },
    "mfa_enrolled": {
      "type": "boolean"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disabled_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "deleted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "sub",
    "tenant_id",
    "preferred_username",
    "password_hash",
    "email_verified",
    "mfa_enrolled",
    "roles",
    "created_at"
  ]
}
